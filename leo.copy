<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Leo Feelow | Universo 5PM</title>
    <meta name="description" content="Mundo individual de Leo Feelow dentro de Cinco Pecados Musicales." />
    <link rel="stylesheet" href="styles.css" />
    <link rel="stylesheet" href="smoke.css" />
    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            background-color: #050505;
            color: #f4eee3;
            overflow-x: hidden;
        }

        body { font-family: 'Helvetica Neue', Arial, sans-serif; }
        h1, h2, blockquote, .brand-mark { font-family: 'Playfair Display', serif; }

        .world-hero {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
            background-color: #000;
            margin: 0;
            padding: 0;
            display: block;
            perspective: 1400px;
        }

        #hero-canvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            display: block;
            border: none;
            outline: none;
            image-rendering: auto;
            filter: brightness(0.99) contrast(1.08) saturate(1.09);
            transform: translateZ(-95px) scale(1.125);
            transform-origin: center center;
        }

        .hero-color-curtain {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            background:
                radial-gradient(120% 78% at 52% 44%, rgba(130,130,130,0.14) 0%, rgba(48,48,48,0.24) 55%, rgba(0,0,0,0.13) 100%),
                linear-gradient(180deg, rgba(96,96,96,0.18) 0%, rgba(34,34,34,0.16) 45%, rgba(0,0,0,0.08) 100%);
            mix-blend-mode: screen;
        }

        .hero-black-veil {
            position: absolute;
            inset: 0;
            z-index: 2;
            pointer-events: none;
            background: rgba(0,0,0,0.16);
        }

        .hero-readability {
            position: absolute;
            inset: 0;
            z-index: 3;
            background: radial-gradient(circle at center, rgba(0,0,0,0.10) 0%, rgba(0,0,0,0.42) 70%, rgba(0,0,0,0.60) 100%);
            pointer-events: none;
        }

        .hero-grain {
            position: absolute;
            inset: 0;
            z-index: 4;
            pointer-events: none;
            opacity: 0.085;
            background-image:
                radial-gradient(circle at 25% 35%, rgba(255,255,255,0.85) 0 0.55px, transparent 0.7px),
                radial-gradient(circle at 75% 65%, rgba(255,255,255,0.85) 0 0.55px, transparent 0.7px);
            background-size: 3px 3px, 4px 4px;
            mix-blend-mode: soft-light;
        }

        .hero-dust {
            position: absolute;
            inset: -10%;
            z-index: 5;
            pointer-events: none;
            mix-blend-mode: screen;
            opacity: 0.68;
            filter: blur(0.15px) saturate(1.1);
            background:
                radial-gradient(circle at 8% 18%,  rgba(220,220,220,0.86) 0 1.6px, transparent 2.5px),
                radial-gradient(circle at 21% 62%, rgba(172,172,172,0.82) 0 1.8px, transparent 2.7px),
                radial-gradient(circle at 36% 34%, rgba(192,192,192,0.78) 0 1.4px, transparent 2.3px),
                radial-gradient(circle at 52% 52%, rgba(150,150,150,0.82) 0 1.9px, transparent 2.8px),
                radial-gradient(circle at 68% 24%, rgba(204,204,204,0.78) 0 1.5px, transparent 2.5px),
                radial-gradient(circle at 84% 68%, rgba(158,158,158,0.82) 0 1.8px, transparent 2.8px),
                radial-gradient(circle at 93% 36%, rgba(214,214,214,0.72) 0 1.3px, transparent 2.2px);
            background-size:
                320px 320px,
                360px 360px,
                300px 300px,
                420px 420px,
                330px 330px,
                380px 380px,
                300px 300px;
            animation: dustDriftA 13s linear infinite;
        }

        .hero-dust::before,
        .hero-dust::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            mix-blend-mode: screen;
        }

        .hero-dust::before {
            opacity: 0.6;
            background:
                radial-gradient(circle at 14% 42%, rgba(198,198,198,0.78) 0 1.3px, transparent 2.2px),
                radial-gradient(circle at 29% 18%, rgba(160,160,160,0.76) 0 1.7px, transparent 2.6px),
                radial-gradient(circle at 44% 74%, rgba(202,202,202,0.74) 0 1.3px, transparent 2.2px),
                radial-gradient(circle at 63% 40%, rgba(168,168,168,0.78) 0 1.6px, transparent 2.5px),
                radial-gradient(circle at 79% 16%, rgba(214,214,214,0.72) 0 1.2px, transparent 2.1px),
                radial-gradient(circle at 90% 80%, rgba(174,174,174,0.76) 0 1.5px, transparent 2.4px);
            background-size: 340px 340px, 380px 380px, 320px 320px, 360px 360px, 310px 310px, 350px 350px;
            animation: dustDriftB 18s ease-in-out infinite alternate;
        }

        .hero-dust::after {
            opacity: 0.48;
            filter: blur(0.5px);
            background:
                radial-gradient(circle at 12% 30%, rgba(232,232,232,0.82) 0 0.9px, transparent 1.7px),
                radial-gradient(circle at 38% 58%, rgba(198,198,198,0.72) 0 0.9px, transparent 1.7px),
                radial-gradient(circle at 58% 28%, rgba(220,220,220,0.78) 0 1px, transparent 1.8px),
                radial-gradient(circle at 77% 61%, rgba(184,184,184,0.72) 0 0.8px, transparent 1.6px),
                radial-gradient(circle at 91% 34%, rgba(210,210,210,0.76) 0 0.9px, transparent 1.7px);
            background-size: 220px 220px, 260px 260px, 240px 240px, 230px 230px, 250px 250px;
            animation: dustDriftC 22s linear infinite;
        }

        @keyframes dustDriftA {
            0%   { transform: translate3d(0,0,0) scale(1); }
            50%  { transform: translate3d(-2.5%, 1.4%, 0) scale(1.02); }
            100% { transform: translate3d(-4.5%, 0.8%, 0) scale(1.03); }
        }
        @keyframes dustDriftB {
            0%   { transform: translate3d(0,0,0) scale(1); }
            100% { transform: translate3d(2.2%, -1.8%, 0) scale(1.015); }
        }
        @keyframes dustDriftC {
            0%   { transform: translate3d(0,0,0); opacity: 0.45; }
            50%  { opacity: 0.6; }
            100% { transform: translate3d(-2.1%, -1.3%, 0); opacity: 0.5; }
        }

        .kling-patch {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 200px;
            height: 60px;
            background: #000;
            z-index: 7;
            pointer-events: none;
        }

        .world-title {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            text-align: center;
            z-index: 10;
            pointer-events: none;
            padding: 0 1rem;
        }

        .hero-main-wrap {
            position: relative;
            display: inline-block;
        }

        .world-title h1 {
            margin: 0;
            font-size: clamp(4.2rem, 10.8vw, 9.2rem);
            line-height: 0.9;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.025em;
            background: linear-gradient(180deg, #f0f0f0 0%, #b8b8b8 36%, #777777 68%, #242424 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: #a9a9a9;
            -webkit-text-fill-color: transparent;
            text-shadow:
                0 2px 0 rgba(255, 205, 188, 0.16),
                0 8px 18px rgba(0,0,0,0.80),
                0 0 50px rgba(92, 92, 92, 0.56);
            filter: drop-shadow(0 0 18px rgba(170, 170, 170, 0.24));
        }

        /* SUBTÍTULO AJUSTADO */
        .world-subtitle {
            margin: 1.05rem auto 0;
            font-size: clamp(2rem, 4.2vw, 3.4rem); /* +8% aprox */
            font-style: italic;
            font-weight: 650;
            letter-spacing: 0.13em;
            text-transform: uppercase;
            line-height: 1.05;
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 1.15rem;
            opacity: 0;
            transform: translateY(18px);

            background:
                repeating-linear-gradient(
                    135deg,
                    rgba(255, 236, 220, 0.97) 0px,
                    rgba(255, 236, 220, 0.97) 2px,
                    rgba(205, 205, 205, 0.92) 2px,
                    rgba(205, 205, 205, 0.92) 4px
                ),
                linear-gradient(180deg, #eeeeee 0%, #b0b0b0 52%, #777777 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;

            text-shadow:
                0 2px 10px rgba(0,0,0,0.8),
                0 0 25px rgba(142, 142, 142, 0.40); /* +15% glow aprox */
            filter: drop-shadow(0 0 9px rgba(188, 188, 188, 0.22)); /* +15% */
        }

        .world-subtitle::before,
        .world-subtitle::after {
            content: "";
            width: clamp(78px, 9vw, 152px); /* un poco más largas */
            height: 2px;
            background: linear-gradient(90deg, transparent 0%, #b8b8b8 45%, #ededed 50%, #b8b8b8 55%, transparent 100%);
            box-shadow: 0 0 16px rgba(138, 138, 138, 0.72); /* +15% glow aprox */
            transform: translateY(2px);
            border-radius: 2px;
        }

        #loader {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: #000;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: opacity 0.6s ease;
        }
        #loader.hidden { opacity: 0; pointer-events: none; }
        .loader-text {
            color: #777777;
            font-size: 0.92rem;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }
        .progress-track { width: 220px; height: 1px; background: #333; position: relative; }
        .progress-fill { position: absolute; left: 0; top: 0; height: 100%; background: #777777; width: 0%; }

        .content-wrapper {
            position: relative;
            z-index: 20;
            margin: 0;
            overflow: hidden;
            background:
                radial-gradient(950px 360px at 82% 14%, rgba(112,112,112,0.20) 0%, rgba(112,112,112,0.0) 58%),
                radial-gradient(780px 300px at 15% 72%, rgba(52,52,52,0.18) 0%, rgba(52,52,52,0.0) 62%),
                linear-gradient(180deg, #030304 0%, #050505 100%);
        }

        .content-wrapper::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background:
                repeating-linear-gradient(90deg, rgba(255,255,255,0.013) 0 1px, transparent 1px 72px),
                linear-gradient(180deg, rgba(132,132,132,0.07) 0%, transparent 46%);
        }

        .content-wrapper::after {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background:
                radial-gradient(620px 260px at 22% 30%, rgba(112,112,112,0.20) 0%, rgba(112,112,112,0) 68%),
                radial-gradient(700px 300px at 76% 18%, rgba(74,74,74,0.18) 0%, rgba(74,74,74,0) 66%),
                radial-gradient(900px 360px at 48% 62%, rgba(46,46,46,0.14) 0%, rgba(46,46,46,0) 72%);
            mix-blend-mode: screen;
            animation: colorSmokeDrift 14s ease-in-out infinite alternate;
        }

        @keyframes colorSmokeDrift {
            0%   { transform: translate3d(-1.2%, 0, 0) scale(1); opacity: 0.88; }
            50%  { transform: translate3d(1.1%, -0.6%, 0) scale(1.02); opacity: 1; }
            100% { transform: translate3d(-0.7%, 0.7%, 0) scale(1.01); opacity: 0.9; }
        }

        .world-quote {
            padding: 6.9rem 1rem 4.6rem;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .world-quote::before, .world-quote::after {
            content: '';
            display: block;
            width: 1px;
            height: 58px;
            background: #2e2e2e;
            margin: 0 auto 2rem;
        }
        .world-quote::after { margin: 2rem auto 0; }

        .world-quote blockquote {
            font-size: clamp(1.75rem, 3.9vw, 3.05rem);
            font-style: italic;
            color: #d8d8d8;
            max-width: 940px;
            margin: 0 auto;
            line-height: 1.26;
            text-shadow: 0 4px 20px rgba(0,0,0,0.72);
        }

        .world-archive {
            position: relative;
            z-index: 1;
            padding: 4rem 8% 5.3rem;
            max-width: 1600px;
            margin: 0 auto;
        }

        .archive-label {
            display: inline-flex;
            align-items: center;
            gap: 0.72rem;
            color: #9a9a9a;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            margin-bottom: 1rem;
        }
        .archive-label::before {
            content: "";
            width: 22px;
            height: 1px;
            background: #9a9a9a;
        }

        .world-archive h2 {
            font-size: clamp(2.9rem, 6vw, 5.3rem);
            color: #ececec;
            margin: 0 0 2.5rem 0;
            position: relative;
            display: inline-block;
            line-height: 1.02;
        }
        .world-archive h2::after {
            content: '';
            position: absolute;
            bottom: -12px;
            left: 0;
            width: 72px;
            height: 2px;
            background: linear-gradient(90deg, #a8a8a8, transparent);
        }

        .world-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(240px, 1fr));
            gap: 0;
            border: 1px solid #2a2a2a;
            background:
                linear-gradient(180deg, rgba(84,84,84,0.18) 0%, rgba(8,8,9,0.90) 55%, rgba(8,8,9,0.95) 100%);
        }

        .world-grid article {
            background: transparent;
            border-right: 1px solid #2a2a2a;
            padding: 1.55rem 1rem 1rem;
            transition: all 0.35s ease;
            position: relative;
            overflow: hidden;
            min-height: 255px;
        }
        .world-grid article:last-child { border-right: none; }

        .world-grid article:hover {
            transform: translateY(-4px);
            box-shadow: inset 0 0 0 1px rgba(130, 130, 130, 0.58);
        }

        .world-grid article::after {
            content: '';
            position: absolute;
            left: 0.8rem;
            right: 0.8rem;
            bottom: 0.8rem;
            height: 3px;
            background: linear-gradient(90deg, #c8c8c8 0%, #5f5f5f 100%);
            opacity: 0.95;
        }

        .world-grid article span {
            display: block;
            font-size: 1.45rem;
            font-weight: 700;
            color: #a8a8a8;
            text-transform: uppercase;
            letter-spacing: 0.11em;
            margin-bottom: 1rem;
        }

        .world-grid article p {
            color: #bdbdbd;
            line-height: 1.62;
            font-size: 1.04rem;
            margin: 0;
            max-width: 56ch;
        }

        @media (max-width: 992px) {
            .world-grid { grid-template-columns: 1fr; }
            .world-grid article {
                border-right: none;
                border-bottom: 1px solid #2a2a2a;
                min-height: auto;
            }
            .world-grid article:last-child { border-bottom: none; }
        }

        @media (max-width: 768px) {
            .world-archive { padding: 2.8rem 5% 4rem; }
            .world-quote { padding: 4.3rem 1rem 2.8rem; }

            .world-title h1 { font-size: clamp(3.1rem, 12.8vw, 5.1rem); }

            .world-subtitle {
                font-size: clamp(1.34rem, 6.1vw, 2rem);
                gap: 0.65rem;
            }

            .world-subtitle::before,
            .world-subtitle::after {
                width: clamp(40px, 10vw, 60px);
            }
        }
    </style>
</head>
<body class="character-page leo-world">

    <header class="world-header" style="position: absolute; top: 0; left: 0; width: 100%; z-index: 50; padding: 2rem;">
        <a class="brand-mark" href="index.html" style="color: #fff; text-decoration: none; font-size: 1.5rem; font-weight: bold; margin-left: 2rem;">5PM</a>
    </header>

    <main>
        <section class="world-hero" id="hero-scene">
            <div id="loader">
                <div class="loader-text">Marcando el paso</div>
                <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
                <div id="loading-percent" style="color:#666; font-size:0.8rem; margin-top:0.5rem;">0%</div>
            </div>

            <canvas id="hero-canvas"></canvas>
            <div class="hero-color-curtain"></div>
            <div class="hero-black-veil"></div>
            <div class="hero-readability"></div>
            <div class="hero-grain"></div>
            <div class="hero-dust"></div>
            <div class="kling-patch"></div>

            <div class="world-title" id="main-title">
                <div class="hero-main-wrap">
                    <h1 id="hero-main-text">Leo Feelow</h1>
                </div>
                <p class="world-subtitle" id="hero-subtitle">Pecado Musical</p>
            </div>
        </section>

        <div class="content-wrapper">
            <section class="world-quote">
                <blockquote>"No me quedo quieto. Ese es mi único argumento."</blockquote>
            </section>

            <section class="world-archive">
                <div class="archive-label">Contenido Multimedia</div>
                <h2>Historial de Leo Feelow.</h2>

                <div class="world-grid">
                    <article>
                        <span>1vs1 Basket</span>
                        <p>Espacio reservado para retos, victorias, derrotas y clips de pista. El deporte como filosofía urbana sin intermediarios.</p>
                    </article>
                    <article>
                        <span>Graffitis</span>
                        <p>Espacio reservado para piezas, muros, bocetos y registro urbano. La ciudad como lienzo, el trazo como firma.</p>
                    </article>
                    <article>
                        <span>Movimiento</span>
                        <p>Espacio reservado para coreografías, desplazamientos y gestos capturados. El cuerpo que no miente nunca.</p>
                    </article>
                </div>

                <div class="feelow-entry-card">
                    <div class="feelow-entry-text">
                        <span class="feelow-entry-tag">Acceso exclusivo</span>
                        <h3>FEELOW HOOPERS</h3>
                    </div>
                    <a class="feelow-entry-button" href="feelow-hoopers.html">
                        <span>Entrar</span>
                        <i aria-hidden="true">↗</i>
                    </a>
                </div>
            </section>

            <nav class="world-nav" aria-label="Navegación entre personajes">
                <a class="world-nav-link world-nav-prev" href="asher.html"><span>Anterior</span><strong>Asher Coda</strong></a>
                <a class="world-nav-link world-nav-next" href="kim.html"><span>Siguiente</span><strong>Kim Tehk</strong></a>
            </nav>

            <div style="height: 20vh;"></div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

    <script>
        (function() {
            const frameCount = 21;
            const images = [];
            let loadedCount = 0;
            let isInitialized = false;
            let currentFrame = -1;
            let activeFrame = 0;
            let rafPending = false;
            let pendingFrame = 0;

            const canvas = document.getElementById("hero-canvas");
            const ctx = canvas.getContext("2d", { alpha: true });

            const mainTitle = document.getElementById("main-title");
            const heroMainText = document.getElementById("hero-main-text");
            const heroSubtitle = document.getElementById("hero-subtitle");

            const loader = document.getElementById("loader");
            const progressFill = document.getElementById("progress-fill");
            const loadingPercent = document.getElementById("loading-percent");

            function frameSrc(i) {
                return `./images/leo.vid/leo-animacion-${String(i).padStart(3, "0")}.jpg`;
            }

            function setCanvasSize() {
                const dpr = Math.min(window.devicePixelRatio || 1, 2);
                const vw = window.innerWidth;
                const vh = window.innerHeight;

                canvas.width = Math.floor(vw * dpr);
                canvas.height = Math.floor(vh * dpr);
                canvas.style.width = vw + "px";
                canvas.style.height = vh + "px";

                ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
                ctx.imageSmoothingEnabled = true;
                ctx.imageSmoothingQuality = "high";
            }

            function updateLoader() {
                const pct = Math.round((loadedCount / frameCount) * 100);
                progressFill.style.width = `${pct}%`;
                loadingPercent.textContent = `${pct}%`;
            }

            function preloadImages() {
                const promises = [];

                for (let i = 1; i <= frameCount; i++) {
                    const img = new Image();
                    img.decoding = "async";
                    img.src = frameSrc(i);
                    images.push(img);

                    promises.push(
                        new Promise((resolve) => {
                            img.onload = () => {
                                loadedCount++;
                                updateLoader();
                                resolve();
                            };
                            img.onerror = () => {
                                console.warn(`Frame ${i} falló: ${img.src}`);
                                loadedCount++;
                                updateLoader();
                                resolve();
                            };
                        })
                    );
                }

                return Promise.all(promises);
            }

            function drawCover(img) {
                const cw = window.innerWidth;
                const ch = window.innerHeight;
                const iw = img.naturalWidth || img.width;
                const ih = img.naturalHeight || img.height;
                if (!iw || !ih) return;

                const canvasRatio = cw / ch;
                const imgRatio = iw / ih;

                let drawW, drawH, offsetX, offsetY;

                if (canvasRatio > imgRatio) {
                    drawW = cw;
                    drawH = cw / imgRatio;
                    offsetX = 0;
                    offsetY = (ch - drawH) / 2;
                } else {
                    drawH = ch;
                    drawW = ch * imgRatio;
                    offsetX = (cw - drawW) / 2;
                    offsetY = 0;
                }

                const zoom = 1.04;
                const zW = drawW * zoom;
                const zH = drawH * zoom;
                const zX = offsetX - (zW - drawW) / 2;
                const zY = offsetY - (zH - drawH) / 2;

                ctx.clearRect(0, 0, cw, ch);
                ctx.drawImage(img, zX, zY, zW, zH);

                ctx.save();
                ctx.globalAlpha = 0.14;
                ctx.globalCompositeOperation = "overlay";
                ctx.drawImage(img, zX - 0.35, zY, zW, zH);
                ctx.drawImage(img, zX + 0.35, zY, zW, zH);
                ctx.restore();

                ctx.save();
                ctx.globalCompositeOperation = "soft-light";
                ctx.fillStyle = "rgba(118, 118, 118, 0.18)";
                ctx.fillRect(0, 0, cw, ch);
                ctx.restore();
            }

            function renderFrame(index) {
                const i = Math.max(0, Math.min(frameCount - 1, index));
                if (i === currentFrame) return;

                const img = images[i];
                if (!img || !img.complete) return;

                currentFrame = i;
                activeFrame = i;
                drawCover(img);
            }

            function requestRender(index) {
                pendingFrame = index;
                if (rafPending) return;

                rafPending = true;
                requestAnimationFrame(() => {
                    renderFrame(pendingFrame);
                    rafPending = false;
                });
            }

            async function init() {
                setCanvasSize();
                await preloadImages();
                renderFrame(0);

                gsap.to(loader, {
                    opacity: 0,
                    duration: 0.85,
                    ease: "power2.out",
                    onComplete: () => {
                        loader.classList.add('hidden');
                        loader.style.display = 'none';
                    }
                });

                gsap.registerPlugin(ScrollTrigger);
                ScrollTrigger.getAll().forEach(t => t.kill());

                const playhead = { frame: 0 };

                const tl = gsap.timeline({
                    scrollTrigger: {
                        trigger: "#hero-scene",
                        start: "top top",
                        end: "+=360%",
                        pin: true,
                        scrub: 1,
                        anticipatePin: 1,
                        invalidateOnRefresh: true
                    }
                });

                tl.to(heroMainText, {
                    opacity: 0,
                    y: -58,
                    scale: 0.9,
                    duration: 0.42,
                    ease: "power2.inOut"
                }, 0.12);

                tl.to(heroSubtitle, {
                    opacity: 1,
                    y: 0,
                    duration: 0.44,
                    ease: "power2.out"
                }, 0.2);

                tl.to(mainTitle, {
                    y: -70,
                    scale: 0.98,
                    duration: 0.72,
                    ease: "none"
                }, 0.34);

                tl.to(mainTitle, {
                    opacity: 0,
                    duration: 0.40,
                    ease: "power1.in"
                }, 0.80);

                tl.to(playhead, {
                    frame: frameCount - 1,
                    duration: 1,
                    ease: "none",
                    onUpdate: () => requestRender(Math.round(playhead.frame))
                }, 0);

                isInitialized = true;
            }

            let resizeTick = null;
            window.addEventListener('resize', () => {
                if (!isInitialized) return;

                if (resizeTick) cancelAnimationFrame(resizeTick);
                resizeTick = requestAnimationFrame(() => {
                    setCanvasSize();
                    renderFrame(activeFrame);
                    ScrollTrigger.refresh();
                });
            });

            init();
        })();
    </script>
</body>
</html>


